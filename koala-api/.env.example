# ============================================================================
# Koala API — Environment Variables (template)
# ============================================================================
# Bu dosya commit edilebilir ve projenin hangi env var'lara ihtiyaç duyduğunu
# belgeler. Gerçek değerler `.env.local` (lokal) veya Vercel Project Settings
# > Environment Variables (prod/preview) altında tutulur.
#
# Kurulum:
#   cp .env.example .env.local   # sonra değerleri doldur
#
# GÜVENLİK:
# - `.env.local` gitignore'da — asla commit etme.
# - service_role key'leri sadece bu backend'den kullanılır, Flutter client'a
#   geçirme. Flutter client anon key kullanmalı.
# ============================================================================

# ─── Koala Supabase (ana DB) ────────────────────────────────────────────────
# Project URL. Supabase Dashboard > Project Settings > API > Project URL.
SUPABASE_URL=https://xgefjepaqnghaotqybpi.supabase.co

# Service role key (RLS bypass). Admin ops için. SADECE BACKEND.
# Dashboard > Project Settings > API > service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Evlumba Supabase (designer platform — ters köprü) ──────────────────────
EVLUMBA_SUPABASE_URL=https://yyy.supabase.co

# Service role — Evlumba DB'sine shadow homeowner yazmak için bridge kullanıyor.
EVLUMBA_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Public anon key — read-only sorgular için (designer profil vs.).
EVLUMBA_SUPABASE_ANON_KEY=eyJ...

# ─── AI Providers ───────────────────────────────────────────────────────────
# Google AI Studio → Get API Key. Vision + chat için tek key.
GEMINI_API_KEY=AIzaSy...

# SerpAPI (Google Shopping scrape) — ürün arama.
# https://serpapi.com/dashboard
SERPAPI_KEY=

# Moondream (oda analizi — hafif vision model). Opsiyonel.
# https://moondream.ai/
MOONDREAM_API_KEY=

# ─── Bridge Auth ────────────────────────────────────────────────────────────
# Evlumba ↔ Koala arası mesaj köprüsü için paylaşılan gizli anahtar.
# Evlumba tarafındaki webhook caller aynı değeri `x-bridge-secret` header'ında
# göndermeli. Boş bırakırsan bridge check bypass edilir (yalnızca dev için).
BRIDGE_SECRET=

# ─── Public config ──────────────────────────────────────────────────────────
# Bu değer browser'a sızar — sadece public URL'ler koy. Prod için
# https://koala-api-olive.vercel.app, lokal dev için http://localhost:3000.
NEXT_PUBLIC_API_URL=https://koala-api-olive.vercel.app

# NODE_ENV Vercel tarafından otomatik set edilir; lokal dev için npm script
# yönetir. Manuel dokunma.
