{
  "name": "WF-04A: Kaydetme Teşvik Push",
  "description": "Her gün 19:00 — giriş yapıp 0 kaydetme yapanlara hatırlatma push",
  "trigger": "Schedule: Her gün 19:00",
  "ram_limit": "1GB",
  "nodes": [
    {
      "step": 1,
      "type": "Schedule Trigger",
      "name": "Her Gün 19:00",
      "config": {
        "cron": "0 19 * * *"
      }
    },
    {
      "step": 2,
      "type": "Supabase",
      "name": "Get Users Without Saves Today",
      "config": {
        "operation": "rpc or raw SQL",
        "query": "SELECT u.id, u.display_name FROM users u WHERE u.last_login_at >= now() - interval '24 hours' AND u.id NOT IN (SELECT DISTINCT user_id FROM saved_items WHERE created_at >= now() - interval '24 hours') LIMIT 50",
        "note": "Son 24 saatte giriş yapıp kaydetme yapmayan, max 50"
      }
    },
    {
      "step": 3,
      "type": "Loop",
      "name": "For Each User",
      "config": {
        "items": "{{users}}"
      }
    },
    {
      "step": "3a",
      "type": "Supabase",
      "name": "Get Push Tokens",
      "config": {
        "table": "koala_push_tokens",
        "filter": "user_id=eq.{{user_id}}&is_active=eq.true"
      }
    },
    {
      "step": "3b",
      "type": "HTTP Request",
      "name": "Send FCM Push",
      "config": {
        "condition": "tokens.length > 0",
        "notification": {
          "title": "Bugün beğendiğin tasarımları kaydetmeyi unutma! 💾",
          "body": "Koala'da keşfettiğin tasarımları koleksiyonlarına ekle"
        },
        "data": {
          "type": "save_reminder"
        }
      }
    }
  ]
}
